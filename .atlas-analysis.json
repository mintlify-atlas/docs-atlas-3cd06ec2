  "keyFeatures": [
    "Multi-language SDKs (JavaScript/TypeScript, Go, Python)",
    "Unified API for 100+ AI models from multiple providers",
    "Type-safe structured output generation",
    "Tool calling and agentic workflows",
    "RAG (Retrieval-Augmented Generation)",
    "Built-in developer UI and CLI",
    "Production monitoring and observability",
    "Plugin architecture for extensibility",
    "Streaming support for real-time responses",
    "Deploy anywhere (Firebase, Cloud Run, or any platform)"
  ],
  "publicApiSurface": [
    "genkit() - Main initialization function",
    "generate() - Text and content generation",
    "generateStream() - Streaming generation",
    "defineFlow() - Create AI workflows",
    "defineTool() - Define tools for models",
    "definePrompt() - Create reusable prompts",
    "embed() - Generate embeddings",
    "retrieve() - Retrieve documents (RAG)",
    "evaluate() - Evaluate AI outputs",
    "modelRef() - Reference AI models",
    "Plugin interface - Extend framework capabilities",
    "CLI commands - genkit start, genkit flow:run"
  ]
}
